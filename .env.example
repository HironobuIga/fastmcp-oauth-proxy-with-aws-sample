# Copy to .env and fill in (scripts/deploy_cognito.sh generates these automatically)
AWS_REGION=ap-northeast-1
USER_POOL_ID=ap-northeast-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server ports
PORT_CIMD=8001
PORT_DCR=8002
PORT_TRADITIONAL=8003

# Public HTTPS CIMD metadata URL. scripts/prepare_cimd_gist.sh can fill this.
CIMD_DOC_URL=

# Pre-registered client for "traditional" pattern (Pattern 3).
# scripts/prepare_traditional_client.sh can fill these before first start.
TRADITIONAL_MCP_CLIENT_ID=
TRADITIONAL_MCP_CLIENT_SECRET=
